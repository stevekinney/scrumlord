{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v tasks >/dev/null 2>&1 && tasks agent-hook codex || true",
            "timeout": 10
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v tasks >/dev/null 2>&1 && tasks agent-hook codex || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v tasks >/dev/null 2>&1 && tasks agent-hook codex || true",
            "timeout": 10
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v tasks >/dev/null 2>&1 && tasks agent-hook codex || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
